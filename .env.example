# Servidor
PORT=3001
NODE_ENV=production

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/frontline

# JWT Secret (troque por uma chave forte)
JWT_SECRET=sua_chave_secreta_muito_forte_aqui

# Webhook secret (mesma chave configurada no EA do MT5)
WEBHOOK_SECRET=chave_secreta_webhook_frontline

# Hotmart
HOTMART_WEBHOOK_SECRET=seu_hottok_do_hotmart

# URL do frontend (para CORS)
FRONTEND_URL=https://seu-dashboard.vercel.app
